func _assert_current_anchor_dialogue_speakers() -> void:
	for path: String in _collect_files_recursive("res://data/dialogues"):
		if not path.get_file().begins_with("anchor_") or not path.ends_with(".json"):
			continue
		var dialogue := _read_json_dict(path)
		_assert(str(dialogue.get("speaker", "")) == "Memory Guide", "anchor dialogue should use child-facing Memory Guide speaker: %s" % path)
		for line_value: Variant in dialogue.get("lines", []):
			_assert(typeof(line_value) == TYPE_DICTIONARY, "anchor dialogue line should be a dictionary: %s" % path)
			if typeof(line_value) != TYPE_DICTIONARY:
				continue
			var line: Dictionary = line_value
			_assert(str(line.get("speaker", "")) == "Memory Guide", "anchor dialogue line should use Memory Guide speaker: %s" % path)
			_assert(not str(line.get("speaker", "")).contains("Anchor"), "anchor dialogue speaker should not expose internal anchor jargon: %s" % path)


