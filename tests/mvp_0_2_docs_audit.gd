func _assert_current_product_docs(prd: String, gameplay_rework: String, story_design: String) -> void:
	_assert_contains(prd, "新 MVP P0 目标链为：", "PRD should mark the new home-first MVP chain as the current product direction")
	_assert_contains(prd, "`Welcome Box -> Room Starter -> Pet Hello -> Home Pet Care -> First Trip`", "PRD should define the new home prologue chain")
	_assert_contains(prd, "`prologue_room_starter`", "PRD should define the Room Starter quest id")
	_assert_contains(prd, "`prologue_pet_hello`", "PRD should define the Pet Hello quest id")
	_assert_contains(prd, "`prologue_home_pet_care`", "PRD should define the Home Pet Care quest id")
	_assert_contains(prd, "新存档默认从 `HomeLayer` 进入；打开 `world_overview` 后看到 `home + school` 起步构图", "PRD should preserve HomeLayer default and world overview composition")
	_assert_contains(prd, "`MVP 0.2` 仅证明 HomeLayer 起步、Quest Diary、Story Show、ParentSummary 和兼容 ID 可运行。", "PRD should mark old MVP 0.2 as historical validation, not the current product boundary")
	_assert_contains(prd, "`parent_bonus_confirmed_home_prologue_v001`", "PRD should define the new Parent Bonus migration flag")
	_assert_contains(prd, "儿童前台不出现 `lesson panel`、`word list drill`、`review test`、`school app`、`L1/L2/L3`", "PRD should keep child-facing anti-lesson checks strict")
	_assert_contains(prd, "在首访后可进入全量 A-Z `Memory Spark` 回访提取", "PRD should document full A-Z Memory Spark revisit coverage")
	_assert_not_contains(prd, "3 个生活事件型任务", "PRD should not preserve the stale three-event MVP task count")
	for item: Dictionary in [
		{"text": prd, "label": "PRD"},
		{"text": gameplay_rework, "label": "gameplay rework"}
	]:
		var text := str(item["text"])
		var label := str(item["label"])
		_assert_contains(text, "旧口径与当前表达", "%s should distinguish legacy wording from current wording" % label)
		_assert_contains(text, "儿童前台", "%s should explicitly discuss child-facing language" % label)
		_assert_contains(text, "内部", "%s should preserve internal compatibility wording where needed" % label)
		_assert_contains(text, "`School Tour`：旧", "%s should mark School Tour as legacy wording" % label)
		_assert_contains(text, "`ReviewChallenge`：旧", "%s should mark ReviewChallenge as legacy/internal wording" % label)
		_assert_not_contains(text, "`School Tour`：这类显式教学词前台降权", "%s should not keep ambiguous School Tour downgrade wording" % label)
		_assert_not_contains(text, "`ReviewChallenge`：包装成活动", "%s should not keep ambiguous ReviewChallenge wording" % label)
	_assert_contains(story_design, "本表中的篇章名用于内部内容规划、家长解释和章节管理", "story design should scope chapter names away from child-facing UI")
	_assert_contains(story_design, "# 小学英语故事线与生活事件/委托内容设计", "story design title should use life-event/commission wording")
	_assert_contains(story_design, "生活事件命名", "story design should treat events as the naming truth")
	_assert_contains(story_design, "### 2.4 生活事件/委托真相", "story design should not treat levels as the product truth")
	_assert_contains(story_design, "原有教材单元或旧关卡映射必须重述为生活事件/委托", "story design should make life events the actual content model")
	_assert_contains(story_design, "生活事件/委托完成奖励必须回流到长期系统", "story design should describe rewards through event completion")
	_assert_contains(story_design, "### 4.3 序章生活事件/委托基线", "story design should use event baseline wording")
	_assert_contains(story_design, "### 4.4 新 MVP P0 事件链规格", "story design should define the new MVP home prologue event specs")
	_assert_contains(story_design, "`Welcome Box -> Room Starter -> Pet Hello -> Home Pet Care -> First Trip`", "story design should list the new MVP chain")
	_assert_contains(story_design, "`prologue_room_starter`、`prologue_pet_hello`、`prologue_home_pet_care` 是新增建议 ID", "story design should preserve new event IDs as snake_case additions")
	_assert_contains(story_design, "`scene_id: world_overview` / `click_target`", "story design should define First Trip routing expectations")
	_assert_contains(story_design, "儿童前台不出现 `lesson panel`、`word list drill`、`review test`、`school app`、`L1/L2/L3`", "story design should keep child-facing anti-lesson checks strict")
	_assert_not_contains(story_design, "### 2.4 关卡包装真相", "story design should not preserve level-packaging section title")
	_assert_not_contains(story_design, "所有关卡都要被包装成生活事件", "story design should not make levels the underlying product truth")
	_assert_not_contains(story_design, "关卡奖励必须回流", "story design should not use level reward wording")
	_assert_not_contains(story_design, "过关", "story design should not use pass-level wording")
	_assert_contains(story_design, "儿童端事件标题仍使用伙伴、节日、带路、准备、展示等生活事件名", "story design should keep child-facing event titles life-based")
	_assert_contains(story_design, "带路、整理、失物招领", "story design should use route-guiding instead of tour wording in the summary table")
	_assert_contains(story_design, "带路、认路、整理", "story design should use route-guiding wording in the chapter detail")
	_assert_contains(story_design, "在首访后可进入全量 A-Z `Memory Spark` 回访提取", "story design should document full A-Z Memory Spark revisit coverage")
	_assert_contains(gameplay_rework, "在首访后可进入全量 A-Z `Memory Spark` 回访提取", "gameplay rework should document full A-Z Memory Spark revisit coverage")


